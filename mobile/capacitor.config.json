{
  "appId": "ai.musashi.app",
  "appName": "Musashi",
  "webDir": "www",
  "server": {
    "url": "https://YOUR_PRODUCTION_URL.workers.dev",
    "cleartext": false,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#f5f0e8",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#8b7355"
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#f5f0e8"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#f5f0e8"
  }
}
