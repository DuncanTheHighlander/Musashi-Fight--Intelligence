{
  "name": "musashi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-dev-ready.mjs",
    "check:dev": "node scripts/check-dev-ready.mjs",
    "check:cloud-pose": "node scripts/check-cloud-pose-ready.mjs",
    "check:prod-env": "node scripts/check-prod-env.mjs --production",
    "check:cf-env": "node scripts/check-prod-env.mjs --cloudflare",
    "prestart": "node scripts/check-prod-env.mjs --production",
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=3072 --dns-result-order=ipv4first\" next dev -p 3000",
    "dev:turbo": "cross-env NODE_OPTIONS=\"--max-old-space-size=3072 --dns-result-order=ipv4first\" next dev --turbopack -p 3000",
    "dev:highmem": "cross-env NODE_OPTIONS=\"--max-old-space-size=3584 --dns-result-order=ipv4first\" next dev -p 3000",
    "dev:lowmem": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048 --dns-result-order=ipv4first\" next dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && pnpm run dev",
    "dev:d1": "cross-env MUSASHI_D1_LOCAL=1 NODE_OPTIONS=\"--max-old-space-size=3072 --dns-result-order=ipv4first\" next dev -p 3000",
    "dev:alt": "cross-env NODE_OPTIONS=\"--max-old-space-size=1024 --dns-result-order=ipv4first\" next dev -H 127.0.0.1 -p 3001",
    "build": "next build",
    "build:cf": "node scripts/clean-open-next.mjs && cross-env NEXT_PRIVATE_STANDALONE=true NEXT_PRIVATE_OUTPUT_TRACE_ROOT=. pnpm build && opennextjs-cloudflare build --skipBuild && node scripts/prepare-cloudflare-output.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm run deploy:cf",
    "deploy:cf": "pnpm run build:cf && wrangler deploy --config wrangler.bundle.toml",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:marketplace": "node scripts/marketplace-test-loop.mjs",
    "test:marketplace:full": "node scripts/marketplace-test-loop.mjs --build",
    "check:launch": "node scripts/marketplace-plug-in-check.mjs",
    "check:launch:strict": "node scripts/marketplace-plug-in-check.mjs --strict",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "gen:coach-brain": "node scripts/generate-coach-brain.mjs",
    "check:mobile-release": "node scripts/check-mobile-release.mjs",
    "mobile:sync": "node scripts/check-mobile-release.mjs && npm --prefix mobile run sync",
    "mobile:android": "node scripts/check-mobile-release.mjs && npm --prefix mobile run android:open",
    "mobile:ios": "node scripts/check-mobile-release.mjs && npm --prefix mobile run ios:open",
    "predeploy": "node scripts/check-prod-env.mjs --cloudflare && pnpm test",
    "test:loop": "node scripts/qa-loop.mjs",
    "test:loop:e2e": "node scripts/qa-loop.mjs --e2e",
    "test:tracking": "node scripts/trackEval.mjs --compare tracking-eval-2026-06-11/baselines.json clip1=tracking-eval-2026-06-11/clip1_replay_v14.json clip2=tracking-eval-2026-06-11/clip2_replay_v14.json clip3=tracking-eval-2026-06-11/clip3_replay_v14.json",
    "fetch:rtm-model": "node scripts/fetch-rtmpose-model.mjs",
    "db:migrate:local": "wrangler d1 migrations apply musashi-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply musashi-db --remote",
    "analyze:corrections": "node scripts/analyze-corrections.mjs",
    "analyze:corrections:fixture": "node scripts/analyze-corrections.mjs --fixture"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@headlessui/react": "^2.2.0",
    "@hookform/resolvers": "^3.10.0",
    "@mediapipe/tasks-vision": "^0.10.21",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-table": "^8.21.2",
    "@vercel/analytics": "^1.4.1",
    "ai": "^4.0.18",
    "caniuse-lite": "1.0.30001281",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.5.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.364.0",
    "mapbox-gl": "^3.10.0",
    "next": "15.5.18",
    "next-themes": "^0.4.4",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.0.0",
    "react-big-calendar": "^1.18.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-map-gl": "^8.0.1",
    "react-resizable-panels": "^2.1.7",
    "react-webcam": "^7.2.0",
    "recharts": "^2.12.4",
    "server-only": "^0.0.1",
    "sonner": "^1.7.2",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "ignore-loader": "^0.1.2",
    "playwright": "^1.61.0",
    "postcss": "^8",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.1",
    "turbo": "^2.3.3",
    "typescript": "^5",
    "vitest": "^2.1.4",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
