# ⚠️ SECURITY WARNING: NEVER commit .env.local to git!
# Copy this file to .env.local and fill in your actual keys

# AI Services
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Models (API IDs from https://ai.google.dev/gemini-api/docs/models)
# Gemini 3 Flash: fast, low-latency. Gemini 3.1 Pro: complex reasoning, agentic.
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_REFLEX_MODEL=gemini-3-flash-preview
GEMINI_TRACK_MODEL=gemini-3-flash-preview
GEMINI_BURST_MODEL=gemini-3.1-pro-preview
GEMINI_STRATEGY_MODEL=gemini-3.1-pro-preview

# OpenAI (optional, fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Payment & Billing
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
MUSASHI_MARKETPLACE_PAYMENTS=mock

# Email Service
EMAIL_SERVICE_URL=https://api.resend.com
EMAIL_API_KEY=re_your_email_api_key
EMAIL_FROM_ADDRESS=noreply@musashi.ai

# Storage Service (Cloudflare R2, AWS S3, etc.)
STORAGE_SERVICE_URL=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=YOUR_STORAGE_ACCESS_KEY
STORAGE_SECRET_KEY=YOUR_STORAGE_SECRET_KEY
STORAGE_BUCKET_NAME=musashi-uploads

# Authentication & Sessions
# Generate a strong random string for SESSION_SECRET (min 32 chars)
MUSASHI_SESSION_SECRET=generate-a-strong-random-string-here-min-32-chars
# ⚠️ CRITICAL: Change default admin credentials immediately!
MUSASHI_SHOGUN_EMAIL=shogun@musashi.ai
MUSASHI_SHOGUN_PASSWORD=ChangeThisSecurePassword123!@#

# SAM 3 Cloud Segmentation (fal.ai)
# Get your API key from: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-ai-api-key-here

# Optional RTMPose cloud pose offload (Modal GPU endpoint)
# Deploy cloud/modal_app.py and paste the exact endpoint URL Modal prints.
# Deploy cloud/modal_cpu_app.py only if you want CPU fallback/benchmarking.
# MUSASHI_POSE_CLOUD_GPU_URL=https://your-gpu-modal-endpoint.modal.run
# MUSASHI_POSE_CLOUD_CPU_URL=https://your-cpu-modal-endpoint.modal.run
# MUSASHI_POSE_CLOUD_TOKEN=generate-a-strong-random-string-here
# MUSASHI_POSE_PROXY_MAX_BYTES=268435456
# MUSASHI_POSE_PROXY_TIMEOUT_MS=290000

# External Integrations
TWILIO_ACCOUNT_SID=AC_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
GOOGLE_MAPS_API_KEY=AIza_YOUR_GOOGLE_MAPS_KEY

# Development/Production
NODE_ENV=development

# Development Settings (NEVER set in production — see src/lib/env.ts)
# Uncomment ONLY for local dev to bypass auth and use a synthetic shogun user.
# MUSASHI_DISABLE_AUTH=1

# ───────────────────────────────────────────────────────────────────────
# Cloudflare D1 Database
# ───────────────────────────────────────────────────────────────────────
# Production/staging: D1 is bound via wrangler.toml (database_id below).
# Database name: musashi-db
# Database ID:  eda3460e-70ab-4eef-b273-0efc52007c82
#
# Local dev options (pick one):
#   A) Real local D1 via wrangler proxy (recommended when testing DB features):
#      MUSASHI_D1_LOCAL=1
#      pnpm db:migrate:local
#      pnpm dev:d1
#   B) In-memory mock (no wrangler needed; seeded marketplace data):
#      MUSASHI_DISABLE_AUTH=1
#   C) Real local D1 + auth bypass:
#      MUSASHI_D1_LOCAL=1
#      MUSASHI_DISABLE_AUTH=1
#      MUSASHI_USE_MOCK_DB=0
#
# Force in-memory mock even when a real binding exists:
# MUSASHI_USE_MOCK_DB=1
#
# Apply migrations:
#   pnpm db:migrate:local    # local SQLite under .wrangler/
#   pnpm db:migrate:remote   # remote Cloudflare D1 (requires wrangler login)

# MUSASHI_D1_LOCAL=1
# MUSASHI_USE_MOCK_DB=0

# MVP preview sections (Marketplace, Scouting, Coaches, Messages nav + content)
# NEXT_PUBLIC_MUSASHI_PREVIEW_FEATURES=1

# Cron / scheduled jobs (protect /api/cron/* routes in production)
# Cloudflare: wrangler.toml runs marketplace cron every 5 min via src/cloudflare-worker.ts
# Local test: curl -H "X-Cron-Secret: $MUSASHI_CRON_SECRET" http://localhost:3000/api/cron/marketplace
# MUSASHI_CRON_SECRET=generate-a-strong-random-string-here

# Dev mode (MUSASHI_DISABLE_AUTH=1): auth bypass; uses in-memory mock D1 unless
# MUSASHI_D1_LOCAL=1 wires real local D1 via wrangler getPlatformProxy.
# Set MUSASHI_USE_MOCK_DB=0 to require real D1 when auth is disabled.

# Stripe Pro plan price ID (billing checkout)
# MUSASHI_STRIPE_PRICE_ID_PRO=price_xxxxxxxx

# Shogun invite code for elevated signup (optional)
# MUSASHI_SHOGUN_INVITE_CODE=your-invite-code

# Optional: Enable debug analytics (sends to localhost:7304 when set to 1)
# NEXT_PUBLIC_DEBUG_LOGGING=1

# ───────────────────────────────────────────────────────────────────────
# OFFLINE / ZERO-SPEND MODE
# ───────────────────────────────────────────────────────────────────────
# Set ALL THREE to exercise the app end-to-end (skeleton tracking, overlays,
# UI) with ZERO paid API calls. Good for demos and local testing after a
# runaway API bill. When any of these are set to "1":
#   - Gemini 3.1 Pro coaching returns a mock payload
#   - /api/fight and /api/fight/analyze short-circuit to mocks
#   - Video upload to Gemini Files is skipped (MediaPipe still runs locally)
#   - /api/fal/proxy returns a mock (no fal.ai charges)
#
# OFFLINE_MODE=1
# GEMINI_DRY_RUN=1
# FAL_DRY_RUN=1
# NEXT_PUBLIC_OFFLINE_MODE=1

# ───────────────────────────────────────────────────────────────────────
# AI COST PROTECTION (Phase 1 + 2 of MVP hardening)
# ───────────────────────────────────────────────────────────────────────
# Global kill switch. When set to "1", every AI-spending route
# (/api/coach, /api/fight/analyze, /api/fight/analyze-burst,
# /api/fight/analyze-strategy) returns HTTP 503 with `code: AI_KILL_SWITCH`
# and DOES NOT touch Gemini. Useful when a billing alert lands — flip this
# secret in Cloudflare / restart pnpm dev to stop all AI spend instantly,
# no redeploy required.
#
# MUSASHI_AI_KILL_SWITCH=1

# Coaching response cache. Per-process LRU keyed on the SHA-256 of the
# Gemini prompt + videoFileUri. Identical requests inside the TTL are
# served from memory, never hitting Gemini.
# Defaults: 5 minute TTL, 200 entries.
#
# MUSASHI_COACHING_CACHE_TTL_MS=300000
# MUSASHI_COACHING_CACHE_SIZE=200
# MUSASHI_COACHING_CACHE=0   # set to 0 to fully bypass the cache (debugging)
